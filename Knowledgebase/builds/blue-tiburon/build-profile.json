    "tuning_tool": "GKFlasher",
    "tuning_docs": "common/opengk/gkflasher.md",
    "k_line_address": "0x11",
    "k_line_baud": 10400,
    "k_line_init": "Fast Init",

    "avi_assignments": {
      "_note": "OEM ECU — no aftermarket AVI inputs. Sensors use OEM signal paths.",
      "AVI1":  null,
