      "SPI1": null,
      "SPI2": null,
      "SPI3": null,
      "SPI4": null
    },

    "ignition": {
      "type": "wasted_spark",
      "coil_model": "OEM Hyundai (3× dual-output coil packs)",
      "count": 3,
      "dwell_ms": null,
      "mode": "wasted_spark",
      "notes": "3 coil packs, 2 cylinders each. NOT sequential COP."
    },

    "injection": {
      "mode": "sequential",
      "injector_model": "Kefico 9260930004",
      "injector_flow_cc_min": 194,
      "injector_deadtime_ms": null,
      "fuel_pressure_kpa": 310
    },

    "can_buses": {
      "_note": "OEM SIMK43 broadcasts DME1–DME5 on the OEM CAN bus at 500 kbps",
      "CAN0": { "baud": 500000, "connects_to": "OEM BCM / body electronics" }
    }
  },

  "immo": {
    "type": "SMARTRA2",
    "system": "BCM-based (V6) — BCM holds SMARTRA2, asks ECU for start permission",
    "k_line_routing": "OBD2 pin 7 → BCM-IM pin 19 → ECU C133-1 pin 3",
    "default_pin_4digit": "2345",
    "dpn_source": "last 6 VIN chars → github.com/Dante383/smartra-vin-to-pin",
    "neutralize_routine_1": "GKFlasher 0x25 (prerequisite)",
    "neutralize_routine_2": "GKFlasher 0x26 param 0x01 (confirm)",
    "docs": [
      "common/opengk/smartra.md",
      "common/opengk/smartra-protocol.md",
      "common/opengk/gkflasher.md"
    ]
  },

  "pdm": {
    "_note": "No PDM installed. OEM fuse/relay box.",
    "make": null,
    "model": null,
    "outputs": null
  },

  "sensors": {
    "coolant_temp": { "type": "OEM NTC thermistor", "location": "coolant passage, engine block", "signal_to": "ECU (OEM)" },
    "oil_pressure":  { "type": "OEM pressure switch / gauge sender", "location": "oil filter housing", "signal_to": "OEM gauge (AEM aftermarket gauge also installed)" },
