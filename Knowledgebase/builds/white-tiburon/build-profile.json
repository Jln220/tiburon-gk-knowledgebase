{
  "build_id": "white-tiburon",
  "description": "2003 Hyundai Tiburon GT V6 — 24 Hours of Lemons primary race car",
  "year": 2003,
  "chassis": "GK",
  "engine": "G6BA",
  "displacement_cc": 2656,
  "transmission": "Aisin AY6",
  "final_drive": "4.050:1",
  "car_color": "white",
  "use": "lemons_race",

  "ecu": {
    "make": "Haltech",
    "model": "Elite 2500",
    "firmware": null,
    "oem_ecu": false,
    "oem_ecu_model": null,

    "avi_assignments": {
      "AVI1":  { "signal": "fuel_pressure",    "sensor": "Lowdoller 899404", "pin": "26-pin-13",  "wire": "GY/Y shielded" },
      "AVI2":  { "signal": "fuel_temp",        "sensor": "Lowdoller 899405", "pin": "34-pin-16",  "wire": "O/B" },
      "AVI3":  { "signal": "oil_pressure",     "sensor": "Lowdoller 899402", "pin": "34-pin-17",  "wire": "O/R" },
      "AVI4":  { "signal": "oil_temp",         "sensor": "Lowdoller 899403", "pin": "34-pin-2",   "wire": "O/Y" },
      "AVI5":  { "signal": "coolant_pressure", "sensor": "Lowdoller 899406", "pin": "26-pin-20",  "wire": "O/G" },
      "AVI6":  { "signal": "coolant_temp",     "sensor": "Lowdoller 899407", "pin": "26-pin-12",  "wire": "GY/O shielded" },
      "AVI7":  { "signal": "brake_pressure",   "sensor": "Lowdoller 899408", "pin": "26-pin-3",   "wire": "GY" },
      "AVI8":  { "signal": "brake_temp",       "sensor": "Lowdoller 899409", "pin": "26-pin-4",   "wire": "V" },
      "AVI9":  { "signal": "MAP",              "sensor": "factory_oem",      "pin": "34-pin-15",  "wire": "Y" },
      "AVI10": { "signal": "TPS",              "sensor": "factory_oem",      "pin": "34-pin-14",  "wire": "W" }
    },

    "sensor_supply_pins": {
      "5V_100mA":  { "pin": "34-pin-9",  "wire": "O",   "for": "Lowdoller sensors (ratiometric)" },
      "8V_1A":     { "pin": "34-pin-12", "wire": "O/W", "for": "OEM-type sensors / solenoids" }
    },

    "digital_inputs": {
      "SPI1": { "signal": "VSS",          "source": "transaxle C109 Hall IC", "pin": "26-pin-8",  "pulses_per_rev": 4 },
      "DPO1": { "signal": "tacho_output", "target": "OEM cluster tach",       "pin": "34-pin-18", "wire": "V/B", "ppr": 3, "mode": "active_low_12V" }
    },

    "ignition": {
      "type": "COP",
      "coil_model": "Toyota 90919-A2005",
      "count": 6,
      "dwell_ms": 2.1,
      "mode": "sequential",
      "pin_map": {
        "IGN1": "34-pin — see hardware/haltech/main-connector-34-pin-elite2500.md",
        "IGN2": "same",
        "IGN3": "same",
        "IGN4": "same",
        "IGN5": "same",
        "IGN6": "same"
      },
      "coil_connector": {
        "A": "GND (engine block)",
        "B": "trigger (Haltech IGN output)",
        "C": "feedback (leave open)",
        "D": "12V (PDM MP2)"
      }
    },

    "injection": {
      "mode": "sequential",
      "injector_flow_cc_min": null,
      "injector_deadtime_ms": null
    },

    "can_buses": {
      "CAN0": {
        "baud": 1000000,
        "pin_H": "26-pin-23",
        "pin_L": "26-pin-24",
        "wire_H": "W",
        "wire_L": "L",
        "connects_to": "AIM PDM 32 (B22=CANH, B11=CANL)"
      }
    }
  },

  "pdm": {
    "make": "AIM",
    "model": "PDM 32",
    "connector_Black_pins": 35,
    "connector_Grey_pins": 35,
    "_pin_prefix_note": "Black connector = B prefix, Grey connector = G prefix (Race Studio convention)",
    "outputs": {
      "HP1":  { "load": "starter_motor",      "trigger": "STARTER_SAFE",                "current_limit_a": 20, "pins": ["B1","B13"] },
      "HB1":  { "load": "cooling_fan",        "trigger": "ECT_PWM_4band + Ch02/Ch03",   "current_limit_a": 35, "pins": ["G1","G2"] },
      "HP3":  { "load": "fuel_pump",           "trigger": "FUEL_PRIME OR ENGINE_RUNNING","current_limit_a": 15, "pins": ["B24","B25"] },
      "MP1":  { "load": "injector_power",      "trigger": "SafeIgnition",                "current_limit_a": 15, "pins": ["B2"] },
      "MP2":  { "load": "COP_coil_power",      "trigger": "SafeIgnition",                "current_limit_a": 15, "pins": ["B3"] },
      "MP3":  { "load": "horn",                "trigger": "Ch12 (Phase 2+)",             "current_limit_a": 10, "pins": ["B4"] },
      "MP4":  { "load": "brake_lights",        "trigger": "Ch09",                        "current_limit_a": 10, "pins": ["B5"] },
      "MP5":  { "load": "tail_lights",         "trigger": "SafeIgnition",                "current_limit_a": 10, "pins": ["B6"] },
      "MP6":  { "load": "headlights",          "trigger": "Ch04 AND SafeIgnition",       "current_limit_a": 15, "pins": ["B7"] },
      "MP7":  { "load": "coolsuit_pump",       "trigger": "Ch10 AND SafeIgnition",       "current_limit_a": 10, "pins": ["B8"] },
      "MP8":  { "load": "defogger",            "trigger": "Ch11 AND SafeIgnition",       "current_limit_a": 10, "pins": ["B9"] },
      "LP1":  { "load": "ECU_power",           "trigger": "SafeIgnition",                "current_limit_a": 10, "pins": ["B14"] },
      "LP2":  { "load": "dash_power",          "trigger": "SafeIgnition",                "current_limit_a": 10, "pins": ["B15"] },
      "LP3":  { "load": "smartycam_power",     "trigger": "SafeIgnition",                "current_limit_a": 10, "pins": ["B16"] },
      "LP4":  { "load": "GPS_power",           "trigger": "SafeIgnition",                "current_limit_a": 10, "pins": ["B17"] },
      "LP5":  { "load": "wideband_O2_power",   "trigger": "SafeIgnition",                "current_limit_a": 2,  "pins": ["B18"], "_note": "LP5 max 2A" },
      "LP6":  { "load": "cluster_power",       "trigger": "SafeIgnition",                "current_limit_a": 10, "pins": ["B19"] },
      "LP7":  { "load": "warning_LED",         "trigger": "MULTI_WARNING",               "current_limit_a": 5,  "pins": ["B20"] },
      "LP8":  { "load": "alt_exciter",         "trigger": "SafeIgnition",                "current_limit_a": 5,  "pins": ["B21"] }
    }
  },

  "sensors": {
    "coolant_temp":     { "type": "Lowdoller PTC thermistor", "model": "Lowdoller 899407", "location": "coolant hose tee", "signal_to": "AVI6" },
    "coolant_pressure": { "type": "Lowdoller ratiometric",    "model": "Lowdoller 899406", "location": "coolant hose tee", "signal_to": "AVI5" },
    "oil_pressure":     { "type": "Lowdoller ratiometric",    "model": "Lowdoller 899402", "location": "oil sandwich plate", "signal_to": "AVI3" },
    "oil_temp":         { "type": "Lowdoller PTC thermistor", "model": "Lowdoller 899403", "location": "oil sandwich plate", "signal_to": "AVI4" },
    "fuel_pressure":    { "type": "Lowdoller ratiometric",    "model": "Lowdoller 899404", "location": "return line tap (Radium FPR)", "signal_to": "AVI1" },
    "fuel_temp":        { "type": "Lowdoller PTC thermistor", "model": "Lowdoller 899405", "location": "return line tap", "signal_to": "AVI2" },
    "brake_pressure":   { "type": "Lowdoller ratiometric",    "model": "Lowdoller 899408", "location": "brake hard line tee", "signal_to": "AVI7" },
    "brake_temp":       { "type": "Lowdoller PTC thermistor", "model": "Lowdoller 899409", "location": "rotor proximity", "signal_to": "AVI8" },
    "map":              { "type": "factory_oem",               "model": "OEM MAP sensor",   "location": "intake manifold",   "signal_to": "AVI9" },
    "tps":              { "type": "factory_oem",               "model": "OEM TPS",          "location": "throttle body",     "signal_to": "AVI10" },
    "lambda":           { "type": null, "model": null, "location": null }
  },

