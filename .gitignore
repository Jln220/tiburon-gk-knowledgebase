.work/
scripts/.work/

# Claude Code session files
.claude/

# Windows system files
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store

# Python / vector store runtime
__pycache__/
*.pyc
*.pyo
Knowledgebase/common/vector-store/chroma/
Knowledgebase/common/vector-store/chunks.jsonl

# Node / MCP
node_modules/
npm-debug.log

# Editor
.vscode/
*.swp
*.swo
