# Large factory manual OCR files — too large for git (1.4GB total)
# Content extracted to Knowledgebase/common/shop-manual/ and /electrical-manual/
LARGEFILE Searchable_Manuals/

# Source PDFs and datasheets — reference material, not tracked in git
# Extracted content lives in Knowledgebase/ as structured markdown
Sources/

